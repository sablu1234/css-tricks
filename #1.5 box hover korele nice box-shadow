#amra jodi kono button hover korle box-shadow dekate chai 
<button class="btn">button</button>
.btn {
  padding: 10px 30px;
  background: black;
  color: white;
  border: 1px solid #3b82f6;
  border-radius: 8px;
}

.btn:hover{
  box-shadow: 
    0 0 10px #0ff,
    0 0 20px #0ff,
    0 0 40px #0ff;
}
